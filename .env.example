# Yiyin-Bot 项目根目录，用于读取 data/ 与 config/ 下的真实数据
YIYIN_BOT_PATH=/path/to/Yiyin-Bot

# 管理后台登录密码
ADMIN_PASSWORD=change_me

# 网站外部访问基址，例如：http://example.com 或 http://1.2.3.4
SITE_BASE_URL=http://your-domain-or-ip

# 群聊页面 token 密钥，需与 Yiyin-Bot 的 web 插件保持一致
WEB_TOKEN_SECRET=change_me

# 管理后台 JWT 密钥；留空时默认复用 WEB_TOKEN_SECRET
JWT_SECRET=change_me

# token 按自然日失效时使用的时区
TOKEN_TIMEZONE=Asia/Shanghai

# FastAPI 监听地址
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# 远程同步目标，供前端部署脚本使用；nginx 脚本也会默认从这里推导服务地址和部署目录
DATA_SYNC_REMOTE=user@your-server:/path/to/Yiyin-Panel
